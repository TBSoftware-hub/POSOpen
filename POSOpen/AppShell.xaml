<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="POSOpen.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:staffViews="clr-namespace:POSOpen.Features.StaffManagement.Views"
    xmlns:shellViews="clr-namespace:POSOpen.Features.Shell.Views"
    Title="POSOpen">

    <ShellContent
        x:Name="HomeShellContent"
        Title="Mission Control"
        ContentTemplate="{DataTemplate shellViews:HomePage}"
        Route="home" />

    <ShellContent
        x:Name="StaffShellContent"
        Title="Staff"
        ContentTemplate="{DataTemplate staffViews:StaffListPage}"
        Route="staff/list" />

    <ShellContent
        x:Name="ManagerShellContent"
        Title="Manager"
        ContentTemplate="{DataTemplate shellViews:ManagerOperationsPage}"
        Route="manager/operations" />

</Shell>

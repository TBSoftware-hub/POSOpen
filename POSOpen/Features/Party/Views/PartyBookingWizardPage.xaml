<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:partyViewModels="clr-namespace:POSOpen.Features.Party.ViewModels"
             xmlns:partyUseCases="clr-namespace:POSOpen.Application.UseCases.Party"
             x:Class="POSOpen.Features.Party.Views.PartyBookingWizardPage"
             x:DataType="partyViewModels:PartyBookingWizardViewModel"
             Title="Party Booking Wizard">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="16"
          RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />
            <Label Text="{Binding ProcessingState, StringFormat='State: {0}'}"
                   FontSize="12"
                   TextColor="#64748B" />

            <Border Background="#FEF2F2"
                    IsVisible="{Binding HasError}"
                    Padding="10">
                <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" />
            </Border>

            <Border Background="#EFF6FF"
                    Padding="10">
                <Label Text="{Binding StatusMessage}" />
            </Border>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="12">

                <Border Grid.Row="0"
                        IsVisible="{Binding IsDateStep}"
                        Background="#F8FAFC"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Step 1: Choose Date" FontAttributes="Bold" />
                        <DatePicker Date="{Binding PartyDateUtc}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1"
                        IsVisible="{Binding IsTimeStep}"
                        Background="#F8FAFC"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Step 2: Choose Time Slot" FontAttributes="Bold" />
                        <Picker Title="Time slot"
                            SelectedItem="{Binding SelectedSlot}">
                            <Picker.ItemDisplayBinding>
                                <Binding Path="SlotId" />
                            </Picker.ItemDisplayBinding>
                            <Picker.ItemsSource>
                                <Binding Path="AvailableSlots" />
                            </Picker.ItemsSource>
                        </Picker>
                        <CollectionView ItemsSource="{Binding AvailableSlots}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="partyUseCases:BookingSlotAvailabilityDto">
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                        <Label Grid.Column="0" Text="{Binding SlotId}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding IsAvailable, StringFormat='Available: {0}'}"
                                               TextColor="#475569" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2"
                        IsVisible="{Binding IsPackageStep}"
                        Background="#F8FAFC"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Step 3: Choose Package" FontAttributes="Bold" />
                        <Picker Title="Package"
                                ItemsSource="{Binding AvailablePackages}"
                                SelectedItem="{Binding SelectedPackageId}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="3"
                        IsVisible="{Binding IsReviewStep}"
                        Background="#ECFDF5"
                        Padding="12">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Review" FontAttributes="Bold" />
                        <Label Text="{Binding PartyDateUtc, StringFormat='Date: {0:yyyy-MM-dd}'}" />
                        <Label Text="{Binding SelectedSlotId, StringFormat='Slot: {0}'}" />
                        <Label Text="{Binding SelectedPackageId, StringFormat='Package: {0}'}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="Back"
                    Command="{Binding BackCommand}" />

            <Grid Grid.Column="1" ColumnDefinitions="*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                <Button Grid.Row="0"
                        IsVisible="{Binding IsDateStep}"
                        Text="Continue"
                        Command="{Binding ContinueFromDateCommand}" />
                <Button Grid.Row="1"
                        IsVisible="{Binding IsTimeStep}"
                        Text="Continue"
                        Command="{Binding ContinueFromTimeCommand}" />
                <Button Grid.Row="2"
                        IsVisible="{Binding IsPackageStep}"
                        Text="Save Draft"
                        Command="{Binding ContinueFromPackageCommand}" />
                <Button Grid.Row="3"
                        IsVisible="{Binding IsReviewStep}"
                        Text="Confirm Booking"
                        Command="{Binding ConfirmCommand}" />
                <Button Grid.Row="3"
                        Margin="0,46,0,0"
                        IsVisible="{Binding IsBookingConfirmed}"
                        Text="Open Booking Detail"
                        Clicked="OpenBookingDetailClicked" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>

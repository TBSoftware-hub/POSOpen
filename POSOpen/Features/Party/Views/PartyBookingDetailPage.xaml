<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                      xmlns:partyViewModels="clr-namespace:POSOpen.Features.Party.ViewModels"
                      xmlns:partyUseCases="clr-namespace:POSOpen.Application.UseCases.Party"
                      x:Class="POSOpen.Features.Party.Views.PartyBookingDetailPage"
                      x:DataType="partyViewModels:PartyBookingDetailViewModel"
                      Title="Party Booking Detail">

    <CollectionView ItemsSource="{Binding Milestones}">
        <CollectionView.Header>
            <VerticalStackLayout Padding="16" Spacing="12">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Booking Timeline"
                           FontAttributes="Bold"
                           FontSize="18" />
                    <Label Text="{Binding ProcessingState, StringFormat='State: {0}'}"
                           FontSize="12"
                           TextColor="#64748B" />

                    <Border Background="#FEF2F2"
                            IsVisible="{Binding HasError}"
                            Padding="10">
                        <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" />
                    </Border>

                    <Border Background="#EFF6FF"
                            Padding="10">
                        <Label Text="{Binding StatusMessage}" />
                    </Border>
                </VerticalStackLayout>

                <Border Background="#F8FAFC"
                        Padding="12">
                    <Grid ColumnDefinitions="2*,*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="8"
                          RowSpacing="8">
                        <Entry Grid.Row="0"
                               Grid.Column="0"
                               Placeholder="Deposit amount (cents)"
                               Keyboard="Numeric"
                               Text="{Binding DepositAmountInput}" />
                        <Entry Grid.Row="0"
                               Grid.Column="1"
                               Placeholder="Currency"
                               MaxLength="3"
                               Text="{Binding DepositCurrency}" />
                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Text="Save Deposit"
                                Command="{Binding SubmitDepositCommitmentCommand}"
                                IsEnabled="{Binding CanSubmitDeposit}" />

                        <Button Grid.Row="1"
                                Grid.Column="0"
                                Text="Refresh Timeline"
                                Command="{Binding RefreshTimelineCommand}" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Text="Mark Completed"
                                Command="{Binding MarkCompletedCommand}" />
                        <ActivityIndicator Grid.Row="1"
                                           Grid.Column="2"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Room Assignment Section -->
                <Border Background="#F0FDF4"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Room Assignment"
                               FontAttributes="Bold"
                               FontSize="14" />

                        <Label Text="{Binding AssignedRoomId, StringFormat='Assigned Room: {0}'}"
                               TextColor="#15803D" />

                        <Picker ItemsSource="{Binding RoomOptions}"
                                SelectedItem="{Binding SelectedRoom}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                Title="Select a room" />

                        <Button Text="Assign Room"
                                Command="{Binding AssignRoomCommand}" />

                        <Border Background="#FEF2F2"
                                IsVisible="{Binding HasConflict}"
                                Padding="10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding ConflictMessage}"
                                       TextColor="#DC2626"
                                       FontAttributes="Bold" />
                                <Label Text="Alternative rooms:"
                                       FontSize="12"
                                       TextColor="#374151" />
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding AlternativeRooms}"
                                                    Spacing="2">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Label Text="{Binding .}"
                                                   TextColor="#1D4ED8"
                                                   FontSize="12"
                                                   Margin="8,0,0,0" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                                <Label Text="Alternative slots:"
                                       FontSize="12"
                                       TextColor="#374151" />
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding AlternativeSlots}"
                                                    Spacing="2">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Label Text="{Binding .}"
                                                   TextColor="#1D4ED8"
                                                   FontSize="12"
                                                   Margin="8,0,0,0" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Background="#FFFBEB"
                        Padding="12">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto"
                              ColumnSpacing="8">
                            <Label Grid.Column="0"
                                   Text="Catering &amp; Decor"
                                   FontAttributes="Bold"
                                   FontSize="14" />
                            <ActivityIndicator Grid.Column="1"
                                               IsRunning="{Binding IsAddOnBusy}"
                                               IsVisible="{Binding IsAddOnBusy}" />
                        </Grid>

                        <Label Text="Catering options"
                               FontAttributes="Bold"
                               FontSize="12" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding CateringOptions}"
                                            Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="partyUseCases:AddOnOptionItemDto">
                                    <Border Background="#FFFFFF"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            Padding="8">
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="8">
                                            <Label Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontAttributes="Bold" />
                                            <Label Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="{Binding PriceCents, StringFormat='${0:F0} cents'}"
                                                   FontSize="12"
                                                   TextColor="#6B7280" />
                                            <Label Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="At Risk"
                                                   IsVisible="{Binding IsAtRisk}"
                                                   TextColor="#B45309"
                                                   FontSize="11"
                                                   FontAttributes="Bold" />
                                            <Button Grid.Row="0"
                                                    Grid.Column="2"
                                                    Grid.RowSpan="2"
                                                    Text="Toggle"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type partyViewModels:PartyBookingDetailViewModel}}, Path=ToggleAddOnOptionCommand}"
                                                    CommandParameter="{Binding OptionId}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Label Text="Decor options"
                               FontAttributes="Bold"
                               FontSize="12" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding DecorOptions}"
                                            Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="partyUseCases:AddOnOptionItemDto">
                                    <Border Background="#FFFFFF"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            Padding="8">
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="8">
                                            <Label Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontAttributes="Bold" />
                                            <Label Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="{Binding PriceCents, StringFormat='${0:F0} cents'}"
                                                   FontSize="12"
                                                   TextColor="#6B7280" />
                                            <Label Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="At Risk"
                                                   IsVisible="{Binding IsAtRisk}"
                                                   TextColor="#B45309"
                                                   FontSize="11"
                                                   FontAttributes="Bold" />
                                            <Button Grid.Row="0"
                                                    Grid.Column="2"
                                                    Grid.RowSpan="2"
                                                    Text="Toggle"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type partyViewModels:PartyBookingDetailViewModel}}, Path=ToggleAddOnOptionCommand}"
                                                    CommandParameter="{Binding OptionId}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Label Text="{Binding AddOnTotalAmountCents, StringFormat='Add-ons total: {0} cents'}"
                               FontAttributes="Bold" />

                        <Button Text="Save Add-ons"
                            Command="{Binding SaveAddOnSelectionsCommand}" />

                        <Label Text="{Binding AddOnStatusMessage}"
                               FontSize="12"
                               TextColor="#334155" />

                        <Border Background="#FEF2F2"
                                IsVisible="{Binding HasRisks}"
                                Padding="10">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Risk Indicators"
                                       FontAttributes="Bold"
                                       TextColor="#B91C1C" />
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding RiskIndicators}"
                                                    Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="partyUseCases:BookingRiskIndicatorDto">
                                            <Border Background="#FFFFFF"
                                                    Stroke="#FCA5A5"
                                                    StrokeThickness="1"
                                                    Padding="8">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding OptionId}"
                                                           FontAttributes="Bold" />
                                                    <Label Text="{Binding RiskSeverity, StringFormat='Severity: {0}'}"
                                                           TextColor="#B91C1C"
                                                           FontSize="12" />
                                                    <Label Text="{Binding RiskReason}"
                                                           FontSize="12" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Milestones and next actions"
                       FontAttributes="Bold" />

            </VerticalStackLayout>
        </CollectionView.Header>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="partyUseCases:PartyBookingTimelineMilestoneDto">
                <Border StrokeThickness="1"
                        Stroke="#E2E8F0"
                        Background="#FFFFFF"
                        Padding="10"
                        Margin="16,0,16,8">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="4">
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Text="{Binding MilestoneKey}"
                               FontAttributes="Bold" />
                        <Label Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding Status}" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding NextActionLabel}" />

                        <Label Grid.Row="2"
                               Grid.Column="0"
                               Text="{Binding EffectiveAtUtc, StringFormat='Effective: {0:yyyy-MM-dd HH:mm} UTC'}"
                               FontSize="12"
                               TextColor="#64748B" />
                        <Label Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding RailLabel}"
                               FontSize="12"
                               TextColor="#0F766E" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admissionsViewModels="clr-namespace:POSOpen.Features.Admissions.ViewModels"
             x:Class="POSOpen.Features.Admissions.Views.FastPathCheckInPage"
             x:DataType="admissionsViewModels:FastPathCheckInViewModel"
             Title="Fast-Path Check-In">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="16"
          RowSpacing="12">

              <Border Grid.Row="0"
                            Background="#DC2626"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12"
                Padding="12">
                     <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                                  Binding="{Binding WaiverStatus}"
                                                  Value="Valid">
                                   <Setter Property="Background" Value="#16A34A" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border"
                                                  Binding="{Binding WaiverStatus}"
                                                  Value="Pending">
                                   <Setter Property="Background" Value="#D97706" />
                            </DataTrigger>
                     </Border.Triggers>
            <VerticalStackLayout Spacing="4">
                <Label Text="Waiver Status"
                       TextColor="White"
                       FontSize="12" />
                <Label Text="{Binding WaiverStatusLabel}"
                       TextColor="White"
                       FontSize="18"
                       FontAttributes="Bold" />
                <Label Text="{Binding GuidanceMessage}"
                       TextColor="White" />
            </VerticalStackLayout>
        </Border>

         <Grid Grid.Row="1"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              RowSpacing="10">
            <Label Grid.Row="0"
                   Text="Selected Family"
                   FontAttributes="Bold" />
            <Label Grid.Row="1"
                   Text="{Binding FamilyDisplayName}"
                   AutomationId="fast-path-family-display" />

            <Border Grid.Row="2"
                    Background="#E0F2FE"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="10">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="Admissions total"
                           TextColor="#0C4A6E"
                           FontAttributes="Bold" />
                    <Label Grid.Column="1"
                           Text="{Binding AdmissionTotalLabel}"
                           TextColor="#0C4A6E"
                           FontAttributes="Bold" />
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Background="#FEF2F2"
                    StrokeThickness="0"
                    IsVisible="{Binding HasError}"
                    StrokeShape="RoundRectangle 8">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#B91C1C"
                       Padding="10" />
            </Border>

            <Border Grid.Row="4"
                    Background="#DCFCE7"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="10"
                    IsVisible="{Binding ShowCompletionResult}">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding IsDeferredQueued}"
                                 Value="True">
                        <Setter Property="Background" Value="#FEF3C7" />
                    </DataTrigger>
                </Border.Triggers>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="4">
                    <Label Grid.Row="0"
                           Text="{Binding CompletionStatusLabel}"
                           FontAttributes="Bold"
                           TextColor="#14532D" />
                    <Label Grid.Row="1"
                           Text="{Binding CompletionGuidance}"
                           TextColor="#14532D" />
                    <Label Grid.Row="2"
                           Text="{Binding ConfirmationCode, StringFormat='Confirmation: {0}'}"
                           TextColor="#14532D" />
                    <Label Grid.Row="3"
                           Text="{Binding OperationIdText, StringFormat='Operation ID: {0}'}"
                           TextColor="#14532D" />
                </Grid>
            </Border>

            <Button Grid.Row="5"
                    Text="Refresh Waiver Status"
                    IsVisible="{Binding ShowRefreshAction}"
                    Command="{Binding RefreshWaiverStatusCommand}" />

            <Button Grid.Row="6"
                    Text="Start Waiver Recovery"
                    IsVisible="{Binding ShowRecoveryAction}"
                    Command="{Binding StartWaiverRecoveryCommand}" />

           <Button Grid.Row="7"
                  Text="Complete Profile"
                  IsVisible="{Binding ShowProfileCompletionAction}"
                  Command="{Binding StartProfileCompletionCommand}" />

           <ActivityIndicator Grid.Row="8"
                               IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}" />
        </Grid>

        <Button Grid.Row="2"
                Text="Complete Check-In"
                Command="{Binding CompleteCheckInCommand}" />
    </Grid>
</ContentPage>

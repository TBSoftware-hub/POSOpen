<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POSOpen.Features.Admissions.Views.FamilyProfilePage"
             Title="Family Profile">

    <Grid Padding="16">
        <VerticalStackLayout Spacing="10">
            <Label Text="Family Profile"
                   FontSize="24"
                   FontAttributes="Bold" />
            <Label x:Name="FamilyIdLabel"
                   AutomationId="family-profile-selected-id"
                   SemanticProperties.Description="Selected family identifier" />
            <Label Text="Profile details will be implemented in Story 2.2+"
                   TextColor="#52606D" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>

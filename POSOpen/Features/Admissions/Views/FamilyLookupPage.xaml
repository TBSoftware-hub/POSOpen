<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admissionsViewModels="clr-namespace:POSOpen.Features.Admissions.ViewModels"
             xmlns:admissionsUseCases="clr-namespace:POSOpen.Application.UseCases.Admissions"
             x:Class="POSOpen.Features.Admissions.Views.FamilyLookupPage"
             x:DataType="admissionsViewModels:FamilyLookupViewModel"
             Title="Family Lookup">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="16"
          RowSpacing="12">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
            <Entry Grid.Column="0"
                   Text="{Binding SearchQuery}"
                   Placeholder="Search by name or phone"
                   AutomationId="family-search-entry"
                   SemanticProperties.Description="Search families by name or phone" />
            <Button Grid.Column="1"
                    Text="Scan"
                    Command="{Binding ScanCommand}"
                    AutomationId="family-scan-button"
                    SemanticProperties.Description="Scan family QR code token" />
        </Grid>

        <Grid Grid.Row="1">
            <VerticalStackLayout IsVisible="{Binding IsLoading}"
                                 Spacing="8"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsLoading}" />
                <Label Text="Searching families..." />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Border Background="#FEF2F2"
                    IsVisible="{Binding HasError}">
                    <Label Text="{Binding ErrorMessage}"
                           Padding="10"
                           TextColor="#DC2626" />
                </Border>

                <CollectionView ItemsSource="{Binding SearchResults}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="admissionsUseCases:FamilySearchResultDto">
                            <Border Margin="0,4"
                                    Padding="10"
                                    Stroke="#D1D5DB"
                                    StrokeShape="RoundRectangle 8"
                                    AutomationId="{Binding DisplayName, StringFormat='family-result-{0}'}">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8"
                                      RowSpacing="4">
                                    <Label Grid.Row="0"
                                           Grid.Column="0"
                                           Text="{Binding DisplayName}"
                                           FontAttributes="Bold"
                                           SemanticProperties.Description="{Binding DisplayName, StringFormat='Family {0}'}" />
                                    <Label Grid.Row="1"
                                           Grid.Column="0"
                                           Text="{Binding Phone}" />

                                    <Border Grid.Row="0"
                                            Grid.Column="1"
                                            Grid.RowSpan="2"
                                            Padding="8,3"
                                            StrokeThickness="0"
                                            Background="#DC2626"
                                            VerticalOptions="Center"
                                            StrokeShape="RoundRectangle 10">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding WaiverStatus}"
                                                         Value="Valid">
                                                <Setter Property="Background" Value="#16A34A" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding WaiverStatus}"
                                                         Value="Pending">
                                                <Setter Property="Background" Value="#D97706" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding WaiverStatusLabel}"
                                               TextColor="White"
                                               FontSize="12" />
                                    </Border>

                                    <Button Grid.Row="1"
                                            Grid.Column="1"
                                            Text="Select"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type admissionsViewModels:FamilyLookupViewModel}}, Path=SelectFamilyCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout IsVisible="{Binding HasNoResults}"
                                     Spacing="8"
                                     Padding="4,8">
                    <Label Text="No matching families found." />
                    <Button Text="Create New Profile"
                            Command="{Binding CreateNewProfileCommand}" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <Button Grid.Row="2"
                Text="Complete Check-In"
                HorizontalOptions="Fill"
                SemanticProperties.Description="Complete check in placeholder" />
    </Grid>
</ContentPage>

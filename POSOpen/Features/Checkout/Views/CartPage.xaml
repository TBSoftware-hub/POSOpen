<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:POSOpen.Features.Checkout.ViewModels"
             x:Class="POSOpen.Features.Checkout.Views.CartPage"
             x:DataType="viewModels:CartViewModel"
             x:Name="cartPage"
             Title="Cart">

	<Grid RowDefinitions="Auto,*,Auto"
	      Padding="16"
	      RowSpacing="12">

		<Grid Grid.Row="0" RowDefinitions="Auto,Auto" RowSpacing="8">
			<ActivityIndicator Grid.Row="0"
			                   IsRunning="{Binding IsLoading}"
			                   IsVisible="{Binding IsLoading}"
			                   HorizontalOptions="Center" />
			<Border Grid.Row="1"
			        Background="#FEF2F2"
			        IsVisible="{Binding HasError}"
			        Padding="10">
				<Label Text="{Binding ErrorMessage}" TextColor="#DC2626" />
			</Border>
		</Grid>

		<CollectionView Grid.Row="1"
		                ItemsSource="{Binding ItemGroups}"
		                IsGrouped="True">
			<CollectionView.GroupHeaderTemplate>
				<DataTemplate x:DataType="viewModels:CartLineItemGroupViewModel">
					<Grid ColumnDefinitions="Auto,*,Auto"
					      Padding="0,8,0,4"
					      ColumnSpacing="6">
						<Label Grid.Column="0" Text="{Binding GroupIcon}" FontSize="18" />
						<Label Grid.Column="1"
						       Text="{Binding GroupName}"
						       FontAttributes="Bold"
						       FontSize="15"
						       VerticalOptions="Center" />
						<Label Grid.Column="2"
						       Text="{Binding SubtotalLabel}"
						       TextColor="#52606D"
						       VerticalOptions="Center"
						       HorizontalTextAlignment="End" />
					</Grid>
				</DataTemplate>
			</CollectionView.GroupHeaderTemplate>
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Border Margin="0,4"
					        Padding="12"
					        Stroke="#D1D5DB"
					        StrokeShape="RoundRectangle 8">
						<Grid RowDefinitions="Auto,Auto"
						      ColumnDefinitions="*,Auto"
						      RowSpacing="8"
						      ColumnSpacing="8">
							<Label Grid.Row="0"
							       Grid.Column="0"
							       Text="{Binding Description}"
							       FontAttributes="Bold"
							       LineBreakMode="TailTruncation" />
							<Label Grid.Row="0"
							       Grid.Column="1"
							       Text="{Binding LineTotalLabel}"
							       FontAttributes="Bold"
							       HorizontalTextAlignment="End" />

							<Grid Grid.Row="1"
							      Grid.Column="0"
							      ColumnDefinitions="Auto,Auto,Auto,Auto"
							      ColumnSpacing="6">
								<Button Grid.Column="0"
								        Text="–"
								        WidthRequest="36"
								        HeightRequest="36"
								        Padding="0"
								        Command="{Binding Source={x:Reference cartPage}, Path=BindingContext.DecrementQuantityCommand}"
								        CommandParameter="{Binding Id}" />
								<Label Grid.Column="1"
								       Text="{Binding Quantity}"
								       VerticalOptions="Center"
								       MinimumWidthRequest="28"
								       HorizontalTextAlignment="Center" />
								<Button Grid.Column="2"
								        Text="+"
								        WidthRequest="36"
								        HeightRequest="36"
								        Padding="0"
								        Command="{Binding Source={x:Reference cartPage}, Path=BindingContext.IncrementQuantityCommand}"
								        CommandParameter="{Binding Id}" />
								<Label Grid.Column="3"
								       Text="{Binding UnitPriceLabel, StringFormat='@ {0}'}"
								       VerticalOptions="Center"
								       TextColor="#52606D" />
							</Grid>

							<Button Grid.Row="1"
							        Grid.Column="1"
							        Text="Remove"
							        TextColor="#DC2626"
							        Background="Transparent"
							        Command="{Binding Source={x:Reference cartPage}, Path=BindingContext.RemoveItemCommand}"
							        CommandParameter="{Binding Id}" />
						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<Grid Grid.Row="2"
		      RowDefinitions="Auto,Auto,Auto"
		      RowSpacing="10">
			<Grid Grid.Row="0"
			      ColumnDefinitions="*,Auto">
				<Label Grid.Column="0"
				       Text="Grand Total"
				       FontSize="18"
				       FontAttributes="Bold"
				       VerticalOptions="Center" />
				<Label Grid.Column="1"
				       Text="{Binding GrandTotalLabel}"
				       FontSize="18"
				       FontAttributes="Bold"
				       HorizontalTextAlignment="End"
				       VerticalOptions="Center" />
			</Grid>
			<Button Grid.Row="1"
			        Text="+ Add Item"
			        Command="{Binding NavigateToAddLineItemCommand}"
			        AutomationId="add-line-item-button" />
			<Button Grid.Row="2"
			        Text="Proceed to Payment"
			        IsEnabled="False"
			        AutomationId="proceed-to-payment-button" />
		</Grid>

	</Grid>
</ContentPage>

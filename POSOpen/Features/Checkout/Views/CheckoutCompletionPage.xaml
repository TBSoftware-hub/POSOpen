<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:POSOpen.Features.Checkout.ViewModels"
             x:Class="POSOpen.Features.Checkout.Views.CheckoutCompletionPage"
             x:DataType="viewModels:CheckoutCompletionViewModel"
             Title="Transaction Complete">

	<Grid RowDefinitions="Auto,*,Auto"
	      Padding="16"
	      RowSpacing="16">

		<VerticalStackLayout Grid.Row="0" Spacing="8">
			<ActivityIndicator IsRunning="{Binding IsLoading}"
			                   IsVisible="{Binding IsLoading}"
			                   HorizontalOptions="Center" />
			<Border Background="#FEF2F2"
			        IsVisible="{Binding HasError}"
			        Padding="12">
				<Label Text="{Binding ErrorMessage}" TextColor="#DC2626" />
			</Border>
		</VerticalStackLayout>

		<VerticalStackLayout Grid.Row="1" Spacing="16">

			<Border Background="#ECFDF5"
			        IsVisible="{Binding IsOnlineCompletion}"
			        Padding="16">
				<VerticalStackLayout Spacing="8">
					<Label Text="Transaction Complete"
					       FontSize="20"
					       FontAttributes="Bold"
					       TextColor="#065F46" />
					<Label Text="{Binding StatusMessage}"
					       TextColor="#065F46" />
				</VerticalStackLayout>
			</Border>

			<Border Background="#FFF7ED"
			        IsVisible="{Binding IsPrintDeferred}"
			        Padding="16">
				<VerticalStackLayout Spacing="8">
					<Label Text="Receipt Deferred"
					       FontAttributes="Bold"
					       TextColor="#92400E" />
					<Label Text="Receipt printing is unavailable. Please provide alternative receipt documentation to the customer."
					       TextColor="#92400E"/>
				</VerticalStackLayout>
			</Border>

			<Border Background="#EFF6FF"
			        Padding="16">
				<VerticalStackLayout Spacing="6">
					<Label Text="{Binding ReceiptStatusMessage}"
					       FontAttributes="Bold" />
					<Label Text="{Binding NextStepsMessage}"
					       TextColor="#1D4ED8" />
					<Label Text="{Binding OperationIdReference, StringFormat='Reference: {0}'}"
					       FontSize="12"
					       TextColor="#6B7280"
					       IsVisible="{Binding HasOperationReference}" />
				</VerticalStackLayout>
			</Border>

		</VerticalStackLayout>

		<Button Grid.Row="2"
		        Text="Start New Transaction"
		        Command="{Binding NewTransactionCommand}" />

	</Grid>
</ContentPage>
